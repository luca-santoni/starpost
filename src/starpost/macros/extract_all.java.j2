// Auto-generated by starpost. CANONICAL extraction macro: in a SINGLE pass over
// the open simulation (one license checkout) it exports ALL reports AND ALL
// monitor plots. Run via:  starccm+ -batch <this>.java [...] file.sim
//
// Outputs (in {{ output_dir }}):
//   <simname>_reports.csv            sim_file,report,value,units
//   <simname>__plot__<plot>.csv      one X column + one column per series
//                                    (STAR-CCM+ StarPlot.export format)
//   <simname>__plots_index.csv       plot,csv_file   (maps plot name -> file)
//
// extract-all-then-filter: dump everything here; the GUI filters by the user's
// selection/profile. Per-item try/catch keeps one failure from aborting the run.
package macro;

import java.io.*;
import star.common.*;

public class extract_all extends StarMacro {

    public void execute() {
        Simulation sim = getActiveSimulation();
        String simPath = sim.getSessionPath();
        String simName = new File(simPath).getName().replaceAll("\\.sim$", "");
        String dir = "{{ output_dir }}";

        exportReports(sim, simName, dir);
        exportPlots(sim, simName, dir);
    }

    private void exportReports(Simulation sim, String simName, String dir) {
        String out = dir + File.separator + simName + "_reports.csv";
        try (PrintWriter w = new PrintWriter(new FileWriter(out))) {
            w.println("sim_file,report,value,units");
            for (Report r : sim.getReportManager().getObjects()) {
                String name = r.getPresentationName();
                try {
                    double v = r.getReportMonitorValue();
                    String units = r.getUnits() != null
                        ? r.getUnits().getPresentationName() : "";
                    w.println(esc(simName) + "," + esc(name) + "," + v + "," + esc(units));
                } catch (Exception e) {
                    w.println(esc(simName) + "," + esc(name) + ",ERROR,");
                }
            }
        } catch (IOException e) {
            sim.println("starpost: failed to write reports CSV: " + e.getMessage());
        }
    }

    private void exportPlots(Simulation sim, String simName, String dir) {
        String indexPath = dir + File.separator + simName + "__plots_index.csv";
        try (PrintWriter idx = new PrintWriter(new FileWriter(indexPath))) {
            idx.println("plot,csv_file");
            for (StarPlot p : sim.getPlotManager().getObjects()) {
                String name = p.getPresentationName();
                String safe = name.replaceAll("[^A-Za-z0-9._-]", "_");
                String csv = simName + "__plot__" + safe + ".csv";
                String csvPath = dir + File.separator + csv;
                try {
                    // Exports the plot's displayed datasets: X column + one
                    // column per series (e.g. Continuity, X-momentum, ...).
                    p.export(csvPath, ",");
                    idx.println(esc(name) + "," + esc(csv));
                } catch (Exception e) {
                    sim.println("starpost: failed to export plot '" + name
                        + "': " + e.getMessage());
                    idx.println(esc(name) + ",ERROR");
                }
            }
        } catch (IOException e) {
            sim.println("starpost: failed to write plots index: " + e.getMessage());
        }
    }

    private String esc(String s) {
        if (s == null) return "";
        if (s.contains(",") || s.contains("\"") || s.contains("\n")) {
            return "\"" + s.replace("\"", "\"\"") + "\"";
        }
        return s;
    }
}

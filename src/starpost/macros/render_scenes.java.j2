// Auto-generated by starpost. Renders scene STILLS (PNG hardcopies) from the open
// simulation. Run via:  starccm+ -batch <this>.java [...] file.sim
//
// This is a SEPARATE macro from extract_all: rendering goes through OpenGL and,
// on a headless/GPU-less machine, can fail or produce black frames — so it is
// kept apart from the rock-solid numeric extraction and only run on demand from
// the Scenes tab.
//
// Outputs (in {{ output_dir }}):
//   <simname>__scene__<scene>.png                  (when no saved view is chosen)
//   <simname>__scene__<scene>__view__<view>.png    (one per saved view chosen)
//   <simname>__media_index.csv                     kind,source,name,file,error
//
// SHOW maps each scene to render -> the scalar/vector displayers to keep visible
// (the user's checked ones). Any OTHER scalar/vector displayer in that scene is
// hidden before the hardcopy; non-scalar/vector displayers (geometry,
// streamlines, ...) are left untouched. VIEW_NAMES are the saved camera views to
// render each scene from; empty renders from the scene's current view. Uses
// scene.printAndWait(file, magnification, width, height), the standard, stable
// image-export call.
//
// Each scene is closed (scene.close()) after its hardcopies to release its
// graphics resources, so memory doesn't accumulate across scenes when several
// are rendered in one session (one license checkout).
package macro;

import java.io.*;
import java.util.*;
import star.common.*;
import star.vis.*;           // Scene, SceneManager, VisView, displayers (not in star.common)

public class render_scenes extends StarMacro {

    private static final int IMG_WIDTH = {{ width }};
    private static final int IMG_HEIGHT = {{ height }};
    private static final int MAGNIFICATION = {{ magnification }};
    // Saved views to render each scene from; empty == the scene's current view.
    private static final String[] VIEW_NAMES = { {{ view_names_java }} };

    // Scene -> scalar/vector displayers to keep visible (checked by the user).
    private static Map<String, Set<String>> showMap() {
        Map<String, Set<String>> m = new HashMap<>();
        {{ show_map_puts }}
        return m;
    }

    public void execute() {
        Simulation sim = getActiveSimulation();
        String simPath = sim.getSessionPath();
        String simName = new File(simPath).getName().replaceAll("\\.sim$", "");
        String dir = "{{ output_dir }}";
        Map<String, Set<String>> show = showMap();

        String indexPath = dir + File.separator + simName + "__media_index.csv";
        try (PrintWriter idx = new PrintWriter(new FileWriter(indexPath))) {
            idx.println("kind,source,name,file,error");
            // getObjects() is typed as SceneBase; narrow to Scene to render.
            for (SceneBase sb : sim.getSceneManager().getObjects()) {
                String name = sb.getPresentationName();
                if (!show.containsKey(name) || !(sb instanceof Scene)) {
                    continue;
                }
                Scene s = (Scene) sb;
                applyVisibility(sim, s, show.get(name));
                try {
                    if (VIEW_NAMES.length == 0) {
                        renderOne(sim, idx, s, simName, dir, name, null);
                    } else {
                        for (String view : VIEW_NAMES) {
                            applyView(sim, s, view);
                            renderOne(sim, idx, s, simName, dir, name, view);
                        }
                    }
                } finally {
                    // Release this scene's graphics resources before the next
                    // scene. Best-effort: never let closing abort the run.
                    try {
                        s.close();
                    } catch (Exception ce) {
                        sim.println("starpost: could not close scene '" + name
                            + "': " + ce.getMessage());
                    }
                }
            }
        } catch (IOException e) {
            sim.println("starpost: failed to write media index: " + e.getMessage());
        }
    }

    // Renders one hardcopy of scene s (optionally from saved view viewName) and
    // records it in the media index. A null viewName uses the current view.
    private void renderOne(Simulation sim, PrintWriter idx, Scene s, String simName,
                           String dir, String name, String viewName) {
        String label = (viewName == null) ? name : name + " (" + viewName + ")";
        String safe = name.replaceAll("[^A-Za-z0-9._-]", "_");
        String img = simName + "__scene__" + safe;
        if (viewName != null) {
            img += "__view__" + viewName.replaceAll("[^A-Za-z0-9._-]", "_");
        }
        img += ".png";
        String imgPath = dir + File.separator + img;
        try {
            // magnification, then pixel width/height
            s.printAndWait(resolvePath(imgPath), MAGNIFICATION, IMG_WIDTH, IMG_HEIGHT);
            idx.println("still," + esc(name) + "," + esc(label) + "," + esc(img) + ",");
            sim.println("starpost: rendered '" + label + "' -> " + img);
        } catch (Exception e) {
            sim.println("starpost: failed to render '" + label + "': " + e.getMessage());
            idx.println("still," + esc(name) + "," + esc(label) + ",,ERROR");
        }
    }

    // Apply the saved view named viewName to the scene's current view. The view
    // is matched by its reflective name (so we don't depend on the concrete view
    // class name) and applied via the VisView base type. Best-effort: a
    // lookup/apply failure is logged, not fatal.
    private void applyView(Simulation sim, Scene s, String viewName) {
        try {
            for (Object o : sim.getViewManager().getObjects()) {
                if (viewName.equals(presentationName(o))) {
                    s.getCurrentView().setView((VisView) o);
                    return;
                }
            }
            sim.println("starpost: saved view '" + viewName + "' not found");
        } catch (Exception e) {
            sim.println("starpost: could not apply view '" + viewName
                + "': " + e.getMessage());
        }
    }

    // getPresentationName() via reflection — avoids depending on a concrete view
    // class name that differs across releases.
    private String presentationName(Object o) {
        try {
            return String.valueOf(
                o.getClass().getMethod("getPresentationName").invoke(o));
        } catch (Exception e) {
            return null;
        }
    }

    // Hide the scalar/vector displayers NOT in keepVisible by setting their
    // opacity to 0; leave checked ones and all other displayer types untouched.
    // The .sim is never saved, so these changes are discarded on exit.
    private void applyVisibility(Simulation sim, Scene s, Set<String> keepVisible) {
        // getObjects() is typed as DisplayerBase; narrow with instanceof.
        for (DisplayerBase d : s.getDisplayerManager().getObjects()) {
            boolean isField = (d instanceof ScalarDisplayer)
                || (d instanceof VectorDisplayer);
            if (!isField || keepVisible.contains(d.getPresentationName())) {
                continue;
            }
            try {
                if (d instanceof ScalarDisplayer) {
                    ((ScalarDisplayer) d).setOpacity(0.0);
                } else {
                    ((VectorDisplayer) d).setOpacity(0.0);
                }
            } catch (Exception e) {
                sim.println("starpost: could not hide displayer '"
                    + d.getPresentationName() + "': " + e.getMessage());
            }
        }
    }

    private String esc(String s) {
        if (s == null) return "";
        if (s.contains(",") || s.contains("\"") || s.contains("\n")) {
            return "\"" + s.replace("\"", "\"\"") + "\"";
        }
        return s;
    }
}
